# Local-only overrides for safe development.
# Copy this file to `.env.local` and keep your shared/project secrets in `.env`.
# Next.js will load `.env.local`, and the local Prisma wrapper scripts in package.json
# also load `.env.local` before running Prisma commands.

# Use a local Postgres database here so local testing never touches the shared Supabase DB.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/text_on_photo_ai_local?schema=public"
